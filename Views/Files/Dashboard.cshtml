@model IEnumerable<SecureFileShare.Models.FileRecord>

@{
    Layout = "_SecureLayout";
    ViewData["BodyFlexClass"] = "";
    var totalFiles = Model.Count();
    var activeLinks = Model.Count(f => f.ExpiryTime > DateTime.Now);
    var storageUsed = (totalFiles * 2.5).ToString("F1");
}

    <!-- SideNavBar -->
    <aside class="fixed left-0 top-0 h-full w-64 bg-[#f1f4f6] dark:bg-[#0e131d] flex flex-col p-6 z-50 transition-colors duration-300">
        <div class="text-2xl font-black text-primary dark:text-[#0052FF] mb-8 font-headline">SecureFileShare</div>
        <div class="flex items-center gap-3 mb-10 px-2">
            <img class="w-10 h-10 rounded-full bg-surface-container-highest object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCFQOYlJdzTZZcbHpHOP54BG4vZLsYlnsHbqVnqCbQOl89MmHYX2jo-l6T2Mg-mANCGVdUdWYitJyw1L7qDd38fX1uYXyH9SnN9kqvP4QdaeYNkRrSinLcv6-GGKHu0MRk4tLQkJpNBrGqKMp0Pxb6sOYH5TkYDqCEv-noxgUjKi1PRfeYv5FapoMRD0GmLcyHjixfHvaSwBehfR_Spx99mTMQ2iMnwC3XvTmPTvQS1p8eWOFmhwwXd7VxG4gfp_orK1u2AIotKCivZ" />
            <div class="overflow-hidden">
                <p class="text-on-surface dark:text-[#dee2f1] font-bold text-sm truncate">User Profile</p>
                <p class="text-on-surface-variant dark:text-[#dee2f1]/50 text-xs truncate">Verified Vault</p>
            </div>
        </div>
        <nav class="flex-1 space-y-2">
            <a class="flex items-center gap-3 px-4 py-3 text-primary dark:text-[#dee2f1] bg-white dark:bg-[#1b202a] rounded-lg border-l-4 border-primary dark:border-[#0052FF] transition-all duration-300 shadow-sm" href="/Files/Dashboard">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">dashboard</span>
                <span class="text-sm font-bold">Dashboard</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-3 text-slate-500 dark:text-[#dee2f1]/50 hover:text-primary dark:hover:text-[#dee2f1] hover:bg-white dark:hover:bg-[#1b202a] hover:shadow-sm transition-all duration-300 group" href="/Files/Index">
                <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">cloud_upload</span>
                <span class="text-sm">Upload</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-3 text-slate-500 dark:text-[#dee2f1]/50 hover:text-primary dark:hover:text-[#dee2f1] hover:bg-white dark:hover:bg-[#1b202a] hover:shadow-sm transition-all duration-300 group" href="#">
                <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">history</span>
                <span class="text-sm">History</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-3 text-slate-500 dark:text-[#dee2f1]/50 hover:text-primary dark:hover:text-[#dee2f1] hover:bg-white dark:hover:bg-[#1b202a] hover:shadow-sm transition-all duration-300 group" href="#">
                <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">settings</span>
                <span class="text-sm">Settings</span>
            </a>
        </nav>
        <div class="pt-6 border-t border-outline-variant/10 space-y-2">
            <a class="flex items-center gap-3 px-4 py-3 text-slate-500 dark:text-[#dee2f1]/50 hover:text-primary dark:hover:text-[#dee2f1] hover:bg-white dark:hover:bg-[#1b202a] transition-all duration-300 group" href="#">
                <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">contact_support</span>
                <span class="text-sm">Support</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-3 text-slate-500 dark:text-[#dee2f1]/50 hover:text-primary dark:hover:text-[#dee2f1] hover:bg-white dark:hover:bg-[#1b202a] transition-all duration-300 group" href="#">
                <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">logout</span>
                <span class="text-sm">Sign Out</span>
            </a>
        </div>
    </aside>
    <!-- Main Content Stage -->
    <main class="ml-64 flex-1 min-h-screen bg-surface dark:bg-[#0f172a] transition-colors duration-300 pb-10">
        <!-- TopAppBar -->
        <header class="flex items-center justify-between px-8 py-4 w-full bg-white/80 dark:bg-[#171c26]/80 backdrop-blur-md sticky top-0 z-40 border-b border-outline-variant/10 transition-colors duration-300">
            <div class="flex items-center gap-8">
                
            </div>
            <div class="flex items-center gap-4">
                <button
                    class="flex items-center gap-2 p-2 rounded-lg hover:bg-[#e5e9eb] dark:hover:bg-slate-700 transition-colors duration-200 active:scale-95 text-[#181c1e] dark:text-slate-400 group"
                    id="dark-mode-toggle" onclick="toggleDarkMode()" title="Toggle Dark Mode">
                    <span class="material-symbols-outlined transition-transform group-hover:rotate-12"
                          data-icon="dark_mode" id="dark-mode-icon">dark_mode</span>
                </button>
               
                <button class="p-2 text-slate-500 dark:text-[#dee2f1]/60 hover:bg-[#e5e9eb] dark:hover:bg-[#252a35] rounded-full transition-colors active:scale-95">
                    <span class="material-symbols-outlined">notifications</span>
                </button>
                <button class="p-2 text-slate-500 dark:text-[#dee2f1]/60 hover:bg-[#e5e9eb] dark:hover:bg-[#252a35] rounded-full transition-colors active:scale-95">
                    <span class="material-symbols-outlined">help</span>
                </button>
            </div>
        </header>
        <div class="p-10 space-y-10">
            <!-- Summary Stats (Bento Style) -->
            <section class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="bg-white dark:bg-[#1b202a] p-6 rounded-xl flex flex-col justify-between h-40 group hover:shadow-lg dark:hover:bg-[#252a35] transition-all duration-300 shadow-sm border border-outline-variant/10 dark:border-transparent cursor-default scale-100 hover:-translate-y-1">
                    <div class="flex justify-between items-start">
                        <span class="text-on-surface-variant/80 dark:text-[#dee2f1]/60 font-label text-[11px] font-bold tracking-widest uppercase">Total Files</span>
                        <span class="material-symbols-outlined text-primary dark:text-[#0052FF]">folder_open</span>
                    </div>
                    <div class="flex items-baseline gap-2">
                        <span class="text-4xl font-headline font-bold text-on-surface dark:text-[#dee2f1]">@totalFiles</span>
                        <span class="text-primary dark:text-tertiary text-xs font-medium">Synced from vault</span>
                    </div>
                </div>
                <div class="bg-white dark:bg-[#1b202a] p-6 rounded-xl flex flex-col justify-between h-40 group hover:shadow-lg dark:hover:bg-[#252a35] transition-all duration-300 shadow-sm border border-outline-variant/10 dark:border-transparent cursor-default scale-100 hover:-translate-y-1">
                    <div class="flex justify-between items-start">
                        <span class="text-on-surface-variant/80 dark:text-[#dee2f1]/60 font-label text-[11px] font-bold tracking-widest uppercase">Estimated Load</span>
                        <span class="material-symbols-outlined text-tertiary dark:text-[#4cd6ff]">database</span>
                    </div>
                    <div>
                        <div class="flex items-baseline gap-2 mb-2">
                            <span class="text-4xl font-headline font-bold text-on-surface dark:text-[#dee2f1]">@storageUsed</span>
                            <span class="text-on-surface-variant/80 dark:text-[#dee2f1]/60 text-lg">MB</span>
                        </div>
                        <div class="w-full bg-surface-container dark:bg-surface-container-highest rounded-full h-1 overflow-hidden">
                            <div class="bg-gradient-to-r from-primary to-tertiary-container dark:from-primary-container dark:to-tertiary-container h-full w-[45%]"></div>
                        </div>
                    </div>
                </div>
                <div class="bg-white dark:bg-[#1b202a] p-6 rounded-xl flex flex-col justify-between h-40 group hover:shadow-lg dark:hover:bg-[#252a35] transition-all duration-300 shadow-sm border border-outline-variant/10 dark:border-transparent cursor-default scale-100 hover:-translate-y-1">
                    <div class="flex justify-between items-start">
                        <span class="text-on-surface-variant/80 dark:text-[#dee2f1]/60 font-label text-[11px] font-bold tracking-widest uppercase">Active Links</span>
                        <span class="material-symbols-outlined text-secondary dark:text-secondary-fixed">link</span>
                    </div>
                    <div class="flex items-baseline gap-2">
                        <span class="text-4xl font-headline font-bold text-on-surface dark:text-[#dee2f1]">@activeLinks</span>
                        <span class="text-on-surface-variant/60 dark:text-[#dee2f1]/40 text-xs">Currently live</span>
                    </div>
                </div>
            </section>
            <!-- Main Action Header -->
            <div class="flex items-center justify-between">
                <div>
                    <h2 class="text-3xl font-headline font-bold tracking-tight text-on-surface dark:text-[#dee2f1]">Active Assets</h2>
                    <p class="text-on-surface-variant/80 dark:text-[#dee2f1]/60 mt-2">Manage and monitor your high-priority encrypted data streams.</p>
                </div>
                <a href="/Files/Index" class="custom-gradient-btn text-white px-8 py-4 rounded-xl flex items-center gap-3 font-semibold hover:-translate-y-1 transition-transform shadow-xl hover:shadow-2xl shadow-primary/20 dark:shadow-[#0052ff]/20 active:scale-95">
                    <span class="material-symbols-outlined">cloud_upload</span>
                    <span>Upload New File</span>
                </a>
            </div>
            <!-- Data Table Container -->
            <div class="glass-card rounded-2xl overflow-hidden shadow-xl dark:shadow-2xl dark:shadow-black/20 border border-outline-variant/20 dark:border-transparent transition-all duration-300">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-surface-container-high/40 dark:bg-surface-container-high/40 text-on-surface-variant dark:text-[#dee2f1]/50 font-label text-[10px] tracking-widest uppercase transition-colors duration-300 border-b border-outline-variant/10 dark:border-transparent">
                                <th class="px-8 py-5 font-semibold">ID</th>
                                <th class="px-8 py-5 font-semibold">Filename</th>
                                <th class="px-8 py-5 font-semibold">Upload Date</th>
                                <th class="px-8 py-5 font-semibold">Expiry</th>
                                <th class="px-8 py-5 font-semibold text-right">Secure Link</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-outline-variant/10 dark:divide-outline-variant/10">
                            @foreach (var file in Model)
                            {
                                var isExpired = file.ExpiryTime < DateTime.Now;
                                <tr class="group hover:bg-surface-container dark:hover:bg-[#1b202a] transition-all duration-200">
                                    <td class="px-8 py-6 text-on-surface-variant/70 dark:text-[#dee2f1]/40 font-mono text-xs font-semibold">#VD-@file.Id</td>
                                    <td class="px-8 py-6">
                                        <div class="flex items-center gap-4">
                                            <div class="w-10 h-10 rounded-lg bg-primary/10 dark:bg-primary/10 flex items-center justify-center text-primary dark:text-[#6b8cff]">
                                                <span class="material-symbols-outlined">description</span>
                                            </div>
                                            <div>
                                                <div class="text-on-surface dark:text-white font-medium">@file.OriginalName</div>
                                                <div class="text-on-surface-variant/60 dark:text-[#dee2f1]/40 text-xs">Dynamic Asset</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-8 py-6 text-on-surface-variant/90 dark:text-[#dee2f1]/80 text-sm font-medium">@file.UploadTime.ToString("MMM dd, yyyy")</td>
                                    <td class="px-8 py-6">
                                        @if (isExpired)
                                        {
                                            <span class="bg-error-container text-error px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider shadow-sm">Expired</span>
                                        }
                                        else
                                        {
                                            <span class="bg-tertiary-container/30 text-tertiary-container dark:text-[#4cd6ff] dark:bg-tertiary-container/20 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider shadow-sm dark:shadow-none">Active</span>
                                        }
                                    </td>
                                    <td class="px-8 py-6 text-right">
                                        <div class="flex items-center justify-end gap-2">
                                                @{
                                                    var linkToUrl = file.DownloadLink.StartsWith("http") ? file.DownloadLink : Url.Action("Download", "Files", new { link = file.DownloadLink }, Context.Request.Scheme);
                                                }
                                            <button onclick="navigator.clipboard.writeText('@linkToUrl')"
                                                    class="bg-white hover:bg-surface dark:bg-surface-container-highest/60 dark:hover:bg-surface-bright px-3 py-1.5 rounded text-xs flex items-center gap-2 transition-colors border border-outline-variant/20 dark:border-outline-variant/10 shadow-sm dark:shadow-none font-medium @(isExpired ? "opacity-30 cursor-not-allowed" : "")"
                                                    @(isExpired ? "disabled" : "")>
                                                <span class="material-symbols-outlined text-sm">content_copy</span>
                                                Copy Link
                                            </button>
                                            <a href="@linkToUrl" target="_blank" class="p-2 text-on-surface-variant/80 hover:text-primary dark:text-[#dee2f1]/60 dark:hover:text-[#6b8cff] transition-colors @(isExpired ? "opacity-30 pointer-events-none" : "")">
                                                <span class="material-symbols-outlined">download</span>
                                            </a>
                                            <form asp-action="Delete" asp-controller="Files" asp-route-id="@file.Id" method="post" class="inline m-0 p-0" onsubmit="return confirm('Are you sure you want to permanently delete this file?');">
                                                <button type="submit" class="p-2 text-on-surface-variant/80 hover:text-error dark:text-[#dee2f1]/60 dark:hover:text-[#ffb4ab] transition-colors" title="Delete File">
                                                    <span class="material-symbols-outlined">delete</span>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                
                @if (!Model.Any())
                {
                    <div class="flex flex-col items-center justify-center py-24 text-center">
                        <div class="w-24 h-24 mb-6 opacity-20 bg-gradient-to-tr from-primary to-tertiary rounded-full blur-2xl"></div>
                        <span class="material-symbols-outlined text-6xl text-on-surface-variant/30 dark:text-[#dee2f1]/20 mb-4">cloud_off</span>
                        <h3 class="text-xl font-semibold text-on-surface/70 dark:text-[#dee2f1]/50">No files detected in this segment</h3>
                        <p class="text-on-surface-variant/60 dark:text-[#dee2f1]/30 text-sm mt-2">Initialize your vault by dragging files into the manager.</p>
                    </div>
                }

                <!-- Subtle Footer Pagination / Info -->
                <div class="px-8 py-4 bg-surface-container/50 dark:bg-surface-container/30 border-t border-outline-variant/10 dark:border-outline-variant/5 flex justify-between items-center text-[11px] font-label text-on-surface-variant/70 dark:text-[#dee2f1]/40 uppercase tracking-widest font-semibold transition-colors duration-300">
                    <span>Showing @Model.Count() assets</span>
                    <div class="flex gap-4">
                        <button class="hover:text-primary dark:hover:text-[#6b8cff] transition-colors">Previous</button>
                        <button class="hover:text-primary dark:hover:text-[#6b8cff] transition-colors">Next</button>
                    </div>
                </div>
            </div>
        </div>
    </main>
    <!-- Image/Texture Background Overlay -->
    <div class="fixed inset-0 pointer-events-none z-[-1] opacity-[0.03] dark:opacity-5">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,_#003890_0%,_transparent_50%)] dark:bg-[radial-gradient(circle_at_50%_50%,_#0052ff_0%,_transparent_50%)]"></div>
    </div>