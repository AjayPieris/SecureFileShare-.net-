@{
    Layout = "_SecureLayout";
    ViewData["BodyFlexClass"] = "flex-col";
}

    <!-- TopAppBar -->
    <header
        class="w-full top-0 sticky z-50 bg-[#f7fafc]/80 backdrop-blur-md dark:bg-slate-900/80 border-b border-outline-variant/10">
        <div class="flex justify-between items-center px-8 py-6 max-w-7xl mx-auto">
            <div class="flex items-center gap-4 reveal-1">
                <span class="text-2xl font-black tracking-tighter text-[#181c1e] dark:text-white font-headline">SecureFileShare</span>
                </div>
                <div class="flex items-center gap-6 reveal-1">
                    <button
                        class="flex items-center gap-2 p-2 rounded-lg hover:bg-[#e5e9eb] dark:hover:bg-slate-700 transition-all duration-200 active:scale-95 text-[#181c1e] dark:text-slate-400 group"
                        id="dark-mode-toggle" onclick="toggleDarkMode()" title="Toggle Dark Mode">
                        <span class="material-symbols-outlined transition-transform group-hover:rotate-12"
                              data-icon="dark_mode" id="dark-mode-icon">dark_mode</span>
                    </button>
                    <button
                        class="flex items-center gap-2 p-2 rounded-lg hover:bg-[#e5e9eb] dark:hover:bg-slate-700 transition-colors duration-200 active:scale-95 text-[#003890] dark:text-[#3b82f6] font-bold">
                        <span class="material-symbols-outlined" data-icon="shield">shield</span>
                    </button>
                    <a href="/Files/Dashboard"
                        class="flex items-center gap-2 p-2 rounded-lg hover:bg-[#e5e9eb] dark:hover:bg-slate-700 transition-colors duration-200 active:scale-95 text-[#181c1e] dark:text-slate-400 opacity-70">
                        <span class="material-symbols-outlined" data-icon="account_circle">account_circle</span>
                    </a>>
                </div>
            </div>
        </header>
        <div class="flex flex-1 overflow-hidden">
            <!-- SideNavBar -->
            <aside
                class="h-screen w-64 left-0 sticky hidden lg:flex flex-col gap-4 p-6 bg-[#f1f4f6] dark:bg-slate-800 transition-colors duration-300 reveal-1">
                <div class="mb-8 px-2">
                    <h2 class="text-xl font-black text-[#181c1e] dark:text-white font-headline">The Vault</h2>
                    <p class="text-xs font-semibold opacity-60 uppercase tracking-widest text-[#005C7A] dark:text-sky-400">
                        Secure Editorial</p>
                    </div>
                    <nav class="flex flex-col gap-1">
                        <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-500 dark:text-slate-400 hover:bg-[#e5e9eb] dark:hover:bg-slate-700 hover:text-[#005C7A] dark:hover:text-sky-400 transition-all font-manrope text-sm font-semibold group"
                               href="#">
                            <span class="material-symbols-outlined transition-transform group-hover:scale-110"
                                  data-icon="folder_lock">lock</span>
                            <span>Vault</span>
                        </a>
                        <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-[#003890] dark:text-sky-400 border-r-4 border-[#003890] dark:border-sky-400 bg-[#ffffff] dark:bg-slate-700 transition-all font-manrope text-sm font-semibold"
                               href="#">
                            <span class="material-symbols-outlined" data-icon="history">history</span>
                            <span>Recent</span>
                        </a>
                        <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-500 dark:text-slate-400 hover:bg-[#e5e9eb] dark:hover:bg-slate-700 hover:text-[#005C7A] dark:hover:text-sky-400 transition-all font-manrope text-sm font-semibold group"
                               href="#">
                            <span class="material-symbols-outlined transition-transform group-hover:scale-110"
                                  data-icon="share">share</span>
                            <span>Shared</span>
                        </a>
                        <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-500 dark:text-slate-400 hover:bg-[#e5e9eb] dark:hover:bg-slate-700 hover:text-[#005C7A] dark:hover:text-sky-400 transition-all font-manrope text-sm font-semibold group"
                               href="#">
                            <span class="material-symbols-outlined transition-transform group-hover:scale-110"
                                  data-icon="verified_user">verified_user</span>
                            <span>Security</span>
                        </a>
                    </nav>
                    <div class="mt-auto">
                        <button
                            class="w-full py-4 rounded-xl bg-gradient-to-br from-primary to-primary-container dark:from-blue-600 dark:to-indigo-600 text-white font-bold flex items-center justify-center gap-2 shadow-lg hover:brightness-105 active:scale-95 transition-all btn-magnetic">
                            <span class="material-symbols-outlined" data-icon="add">add</span>
                            Upload New
                        </button>
                    </div>
                </aside>
                <!-- Main Canvas -->
                <main class="flex-1 overflow-y-auto bg-surface dark:bg-slate-900 relative transition-colors duration-300">
                    <!-- Background Decoration -->
                    <div class="absolute inset-0 pointer-events-none opacity-40 dark:opacity-20 overflow-hidden">
                        <div
                            class="absolute -top-24 -right-24 w-96 h-96 bg-primary-container dark:bg-blue-900 rounded-full blur-[120px]">
                        </div>
                        <div
                            class="absolute -bottom-24 -left-24 w-96 h-96 bg-tertiary-container dark:bg-cyan-900 rounded-full blur-[120px]">
                        </div>
                    </div>
                    <div class="max-w-4xl mx-auto px-8 py-20 relative z-10">
                        <!-- Editorial Header -->
                        <div class="mb-12">
                            <div
                                class="reveal-1 inline-flex items-center gap-2 px-3 py-1 bg-tertiary-container dark:bg-cyan-900/50 rounded-full text-white text-xs font-bold tracking-widest uppercase mb-4">
                                <span class="material-symbols-outlined text-sm" data-icon="lock"
                                      style="font-variation-settings: 'FILL' 1;">lock</span>
                                End-to-End Encrypted
                            </div>
                            <h1
                                class="reveal-2 text-5xl font-extrabold font-headline tracking-tight text-on-surface dark:text-white mb-4">
                                Secure <span class="text-primary dark:text-blue-400">File Relay</span>
                            </h1>
                            <p class="reveal-3 text-on-surface-variant dark:text-slate-400 text-lg max-w-xl leading-relaxed">
                                Upload your documents to our editorial vault. We generate a unique, temporary encrypted link for
                                secure distribution.
                            </p>
                        </div>

                        <!-- Result Message -->
                        @if (ViewBag.Message != null)
                        {
                            <div class="reveal-1 mb-8 p-6 bg-white dark:bg-slate-800 rounded-xl border-l-4 border-primary dark:border-blue-500 shadow-sm transition-all">
                                <div class="flex items-center gap-4">
                                    <div class="p-2 bg-primary/10 dark:bg-blue-500/10 rounded-full shrink-0">
                                        <span class="material-symbols-outlined text-primary dark:text-blue-400"
                                              data-icon="check_circle">check_circle</span>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <h4 class="font-bold text-lg text-on-surface dark:text-white">@ViewBag.Message</h4>
                                        @if (ViewBag.Link != null)
                                        {
                                            <p class="text-on-surface-variant dark:text-slate-400 text-sm mb-3">Your secure download
                                                link has been established.</p>
                                                <div class="flex items-center gap-2">
                                                    <div class="bg-surface-container dark:bg-slate-900 px-4 py-2 rounded-lg font-mono text-primary dark:text-blue-400 font-bold tracking-wider border border-outline-variant/20 dark:border-slate-700 overflow-hidden text-ellipsis whitespace-nowrap">
                                                        @ViewBag.Link
                                                    </div>
                                                    <button onclick="navigator.clipboard.writeText('@Url.Action("Download", "Files", new { link = ViewBag.Link }, Context.Request.Scheme)')"
                                                            class="p-2 hover:bg-surface-container dark:hover:bg-slate-700 rounded-lg transition-colors group"
                                                            title="Copy Full Link">
                                                        <span class="material-symbols-outlined text-sm"
                                                              data-icon="content_copy">content_copy</span>
                                                    </button>
                                                </div>
                                                <p class="mt-4 text-xs font-semibold text-on-surface-variant/60 dark:text-slate-500 uppercase tracking-widest flex items-center gap-1">
                                                    <span class="material-symbols-outlined text-xs" data-icon="timer">timer</span>
                                                    Expires in 24 hours
                                                </p>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }

                            <!-- Upload Interface -->
                            <div
                                class="reveal-4 bg-surface-container-lowest dark:bg-slate-800 rounded-xl shadow-[0_32px_64px_-12px_rgba(24,28,30,0.06)] dark:shadow-[0_32px_64px_-12px_rgba(0,0,0,0.3)] p-10 border border-outline-variant/15 dark:border-slate-700 overflow-hidden transition-colors duration-300">
                                <form asp-action="Upload" asp-controller="Files" class="space-y-8" enctype="multipart/form-data"
                                      method="post">
                                    <div class="relative group">
                                        <input class="hidden" id="fileInput" name="file" required="" type="file" />
                                        <label
                                            class="relative overflow-hidden flex flex-col items-center justify-center w-full min-h-[280px] bg-surface-container-low dark:bg-slate-900/30 border-2 border-dashed border-outline-variant/30 dark:border-slate-700 rounded-xl cursor-pointer hover:bg-surface-container dark:hover:bg-slate-900/50 transition-all group-hover:border-primary/40 dark:group-hover:border-blue-500/40"
                                            for="fileInput">
                                            <!-- Scanning overlay -->
                                            <div class="scan-line hidden group-hover:block"></div>
                                            <div
                                                class="bg-surface-container-lowest dark:bg-slate-700 p-6 rounded-full shadow-sm mb-6 group-hover:scale-110 transition-transform duration-500 pulse-active">
                                                <span class="material-symbols-outlined text-4xl text-primary dark:text-blue-400"
                                                      data-icon="cloud_upload"
                                                      style="font-variation-settings: 'FILL' 0;">cloud_upload</span>
                                            </div>
                                            <span
                                                class="text-xl font-bold font-headline text-on-surface dark:text-white mb-2 transition-transform group-hover:translate-y-[-2px]">Drop
                                                your files here</span>
                                                <span
                                                    class="text-on-surface-variant dark:text-slate-400 text-sm px-8 text-center transition-opacity group-hover:opacity-80">Maximum
                                                    file size: 50MB. Support for PDF, PNG, JPG, and encrypted ZIPs.</span>

                                                    <div id="fileNameDisplay"
                                                         class="mt-4 px-4 py-1.5 bg-primary/10 dark:bg-blue-500/10 text-primary dark:text-blue-400 rounded-full font-bold text-xs hidden">
                                                        <!-- File name will appear here -->
                                                    </div>

                                                    <div
                                                        class="mt-8 px-6 py-2 bg-white dark:bg-slate-800 rounded-full border border-outline-variant/20 dark:border-slate-700 text-xs font-bold uppercase tracking-tighter text-on-surface-variant dark:text-slate-400 shadow-sm group-hover:text-primary dark:group-hover:text-blue-400 group-hover:bg-primary/5 transition-all">
                                                        Browse Local Storage
                                                    </div>
                                                </label>
                                            </div>
                                            <div class="flex flex-col md:flex-row items-center justify-between gap-6 pt-6">
                                                <div class="flex items-center gap-3 text-on-surface-variant dark:text-slate-400 reveal-5">
                                                    <span class="material-symbols-outlined" data-icon="verified_user">verified_user</span>
                                                    <span class="text-sm font-medium">Automatic encryption applied upon upload</span>
                                                </div>
                                                <button
                                                    class="btn-magnetic w-full md:w-auto px-12 py-5 bg-gradient-to-r from-primary to-primary-container dark:from-blue-600 dark:to-indigo-600 text-white rounded-lg font-bold text-lg shadow-[0_12px_24px_-8px_rgba(0,56,144,0.4)] dark:shadow-[0_12px_24px_-8px_rgba(0,0,0,0.5)] hover:shadow-[0_16px_32px_-8px_rgba(0,56,144,0.5)] flex items-center justify-center gap-3"
                                                    type="submit">
                                                    <span class="material-symbols-outlined group-hover:animate-pulse"
                                                          data-icon="send">send</span>
                                                    Initiate Upload
                                                </button>
                                            </div>
                                        </form>
                                        <div class="mt-3"></div>
                                    </div>
                                    <!-- Bento Information Grid -->
                                    <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-6">
                                        <div
                                            class="reveal-5 p-8 bg-surface-container-low dark:bg-slate-800/50 rounded-xl border border-transparent dark:border-slate-700/30 transition-all hover:shadow-lg hover:-translate-y-1">
                                            <span class="material-symbols-outlined text-primary dark:text-blue-400 mb-4"
                                                  data-icon="security">security</span>
                                            <h3 class="font-bold text-lg mb-2 dark:text-white">Military Grade</h3>
                                            <p class="text-sm text-on-surface-variant dark:text-slate-400 leading-relaxed">AES-256 bit
                                                encryption ensures your data remains yours alone during transit.</p>
                                            </div>
                                            <div class="reveal-5 p-8 bg-surface-container-low dark:bg-slate-800/50 rounded-xl border border-transparent dark:border-slate-700/30 transition-all hover:shadow-lg hover:-translate-y-1"
                                                 style="animation-delay: 0.6s">
                                                <span class="material-symbols-outlined text-primary dark:text-blue-400 mb-4"
                                                      data-icon="timer_off">timer_off</span>
                                                <h3 class="font-bold text-lg mb-2 dark:text-white">Self-Destruct</h3>
                                                <p class="text-sm text-on-surface-variant dark:text-slate-400 leading-relaxed">Files and links
                                                    are automatically purged from our servers after exposure.</p>
                                                </div>
                                                <div class="reveal-5 p-8 bg-surface-container-low dark:bg-slate-800/50 rounded-xl border border-transparent dark:border-slate-700/30 transition-all hover:shadow-lg hover:-translate-y-1"
                                                     style="animation-delay: 0.7s">
                                                    <span class="material-symbols-outlined text-primary dark:text-blue-400 mb-4"
                                                          data-icon="visibility_off">visibility_off</span>
                                                    <h3 class="font-bold text-lg mb-2 dark:text-white">Zero Logging</h3>
                                                    <p class="text-sm text-on-surface-variant dark:text-slate-400 leading-relaxed">We never track
                                                        the content of your transmissions or your IP address.</p>
                                                    </div>
                                                </div>
                                            </div>
                                            <!-- Footer -->
                                            <footer class="max-w-7xl mx-auto px-8 py-12 text-center reveal-5" style="animation-delay: 0.8s">
                                                <p
                                                    class="text-on-surface-variant/40 dark:text-slate-500/40 text-sm font-semibold tracking-widest uppercase">
                                                    © 2026 The Secure Editorial — Vault Division
                                                </p>
                                            </footer>
                                        </main>
                                    </div>