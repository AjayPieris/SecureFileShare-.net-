<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - The Secure Editorial</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@600;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "on-surface-variant": "#40484d",
                        "surface": "#f7fafc",
                        "on-tertiary-container": "#73dad9",
                        "on-primary-fixed": "#001848",
                        "secondary": "#52606d",
                        "surface-variant": "#e0e3e5",
                        "on-secondary-fixed": "#0f1d28",
                        "inverse-on-surface": "#eef1f3",
                        "surface-container-high": "#e5e9eb",
                        "secondary-container": "#d5e4f4",
                        "tertiary": "#004545",
                        "error": "#ba1a1a",
                        "on-secondary-fixed-variant": "#3a4855",
                        "on-background": "#181c1e",
                        "primary": "#003890",
                        "error-container": "#ffdad6",
                        "on-surface": "#181c1e",
                        "surface-container-low": "#f1f4f6",
                        "surface-container": "#ebeef0",
                        "tertiary-container": "#005f5f",
                        "on-error": "#ffffff",
                        "on-primary-fixed-variant": "#0040a2",
                        "on-primary": "#ffffff",
                        "on-primary-container": "#b7c9ff",
                        "tertiary-fixed": "#8cf3f3",
                        "inverse-primary": "#b2c5ff",
                        "inverse-surface": "#2d3133",
                        "surface-container-highest": "#e0e3e5",
                        "on-tertiary-fixed": "#002020",
                        "primary-container": "#004dc0",
                        "surface-tint": "#0c56d0",
                        "on-tertiary-fixed-variant": "#004f4f",
                        "on-secondary-container": "#586673",
                        "surface-dim": "#d7dadc",
                        "secondary-fixed-dim": "#bac8d7",
                        "surface-bright": "#f7fafc",
                        "outline": "#70787e",
                        "primary-fixed-dim": "#b2c5ff",
                        "on-tertiary": "#ffffff",
                        "on-error-container": "#93000a",
                        "primary-fixed": "#dae2ff",
                        "on-secondary": "#ffffff",
                        "outline-variant": "#bfc8ce",
                        "background": "#f7fafc",
                        "secondary-fixed": "#d5e4f4",
                        "surface-container-lowest": "#ffffff",
                        "tertiary-fixed-dim": "#6fd7d6"
                    },
                    fontFamily: {
                        "headline": ["Manrope"],
                        "body": ["Inter"],
                        "label": ["Inter"]
                    },
                    borderRadius: { "DEFAULT": "0.125rem", "lg": "0.25rem", "xl": "0.5rem", "full": "0.75rem" },
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }

        /* Glass Cards */
        .glass-card {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }
        html.dark .glass-card {
            background: rgba(27, 32, 42, 0.6);
        }

        /* Buttons */
        .custom-gradient-btn {
            background: linear-gradient(135deg, #003890 0%, #005f5f 100%);
        }
        html.dark .custom-gradient-btn {
            background: linear-gradient(135deg, #0052ff 0%, #006f89 100%);
        }
        .btn-magnetic {
            transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), background-color 0.3s ease;
        }
        .btn-magnetic:hover { transform: translateY(-2px) scale(1.02); filter: brightness(110%); }
        .btn-magnetic:active { transform: translateY(0) scale(0.98); }

        /* Security Pulses / Scans */
        .security-pulse {
            width: 8px; height: 8px; background-color: #0c56d0; border-radius: 50%;
            box-shadow: 0 0 0 0 rgba(12, 86, 208, 0.7); animation: pulse-light 2s infinite;
        }
        html.dark .security-pulse {
            background-color: #4cd6ff; box-shadow: 0 0 0 0 rgba(76, 214, 255, 0.7); animation: pulse-dark 2s infinite;
        }
        @@keyframes pulse-light {
            0% { box-shadow: 0 0 0 0 rgba(12, 86, 208, 0.7); }
            70% { box-shadow: 0 0 0 10px rgba(12, 86, 208, 0); }
            100% { box-shadow: 0 0 0 0 rgba(12, 86, 208, 0); }
        }
        @@keyframes pulse-dark {
            0% { box-shadow: 0 0 0 0 rgba(76, 214, 255, 0.7); }
            70% { box-shadow: 0 0 0 10px rgba(76, 214, 255, 0); }
            100% { box-shadow: 0 0 0 0 rgba(76, 214, 255, 0); }
        }

        @@keyframes shieldPulse {
            0% { box-shadow: 0 0 0 0 rgba(0, 56, 144, 0.1); }
            70% { box-shadow: 0 0 0 15px rgba(0, 56, 144, 0); }
            100% { box-shadow: 0 0 0 0 rgba(0, 56, 144, 0); }
        }
        .pulse-active { animation: shieldPulse 2s infinite; }

        @@keyframes scan {
            0% { transform: translateY(-100%); opacity: 0; }
            50% { opacity: 0.5; }
            100% { transform: translateY(100%); opacity: 0; }
        }
        .scan-line {
            position: absolute; top: 0; left: 0; right: 0; height: 2px;
            background: linear-gradient(90deg, transparent, rgba(0, 56, 144, 0.4), transparent);
            animation: scan 3s ease-in-out infinite; pointer-events: none;
        }

        /* General Reveal Animations */
        @@keyframes revealUp {
            0% { opacity: 0; transform: translateY(30px) scale(0.98); }
            100% { opacity: 1; transform: translateY(0) scale(1); }
        }
        .reveal-1 { animation: revealUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both; }
        .reveal-2 { animation: revealUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both; }
        .reveal-3 { animation: revealUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both; }
        .reveal-4 { animation: revealUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.4s both; }
        .reveal-5 { animation: revealUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.5s both; }

        .fade-in-section { animation: fadeIn 0.5s ease-out forwards; }
        @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        /* Core Overrides */
        html.dark body { background-color: #0f172a; }
        body { transition: background-color 0.3s ease; }
    </style>
    <script>
        function toggleDarkMode() {
            const html = document.documentElement;
            const isDark = html.classList.toggle('dark');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
            updateIcon(isDark);
        }

        function updateIcon(isDark) {
            const icon = document.getElementById('dark-mode-icon');
            if (icon) {
                icon.textContent = isDark ? 'light_mode' : 'dark_mode';
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            const savedTheme = localStorage.getItem('theme');
            const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

            if (savedTheme === 'dark' || (!savedTheme && prefersDark)) {
                document.documentElement.classList.add('dark');
                updateIcon(true);
            } else {
                updateIcon(false);
            }

            // File input label functionality shared
            const input = document.getElementById('fileInput');
            const fileNameDisplay = document.getElementById('fileNameDisplay');
            if (input && fileNameDisplay) {
                input.addEventListener('change', (e) => {
                    const fileName = e.target.files[0]?.name;
                    if (fileName) {
                        fileNameDisplay.textContent = fileName;
                        fileNameDisplay.classList.remove('hidden');
                    }
                });
            }
        });
    </script>
</head>
<body class="bg-surface font-body text-on-surface dark:text-slate-100 min-h-screen transition-colors duration-300 selection:bg-primary/30 flex @ViewData["BodyFlexClass"]">
    @RenderBody()
</body>
</html>
